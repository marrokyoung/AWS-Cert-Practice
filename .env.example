# Required for deployed builds. Points to the API Gateway base URL.
# For local development, create .env.local with the deployed dev API URL.
NEXT_PUBLIC_API_BASE_URL=https://your-api-id.execute-api.us-west-2.amazonaws.com

# Optional. Frontend API request timeout in milliseconds. Defaults to 10000.
NEXT_PUBLIC_API_TIMEOUT_MS=10000
